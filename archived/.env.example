# ---- Telegram Bot ----
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=gamezone_manager_bot

# ---- Server ----
SERVER_PORT=3000
SERVER_HOST=localhost
API_SECRET_KEY=your_secret_key_here

# ---- Database ----
DB_PATH=./data/gamezone.db

# ---- WebSocket ----
WS_PORT=3001

# ---- Mini App ----
MINI_APP_URL=http://localhost:5173

# ---- Admin ----
ADMIN_TELEGRAM_IDS=123456789,987654321

# ---- Game Club sozlamalari ----
DEFAULT_PRICE_PER_HOUR=20000
DEFAULT_PAUSE_LIMIT_MINUTES=15
LOW_BALANCE_WARNING=5000
CURRENCY=UZS
