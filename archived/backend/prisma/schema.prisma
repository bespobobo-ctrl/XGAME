generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLUB_ADMIN
  CUSTOMER
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  password       String
  role           Role      @default(CUSTOMER)
  email          String?   @unique
  firstName      String?
  lastName       String?
  telegramId     String?   @unique
  balance        Float     @default(0)
  
  // Audit
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  ownedClubs     Club[]    @relation("ClubOwner")
  sessions       Session[]
}

model Club {
  id          String     @id @default(uuid())
  name        String
  address     String?
  imageUrl    String?
  isActive    Boolean    @default(true)
  priority    Int        @default(0)
  
  // Owner (Super Admin or Club Admin assigned)
  ownerId     String
  owner       User       @relation("ClubOwner", fields: [ownerId], references: [id])

  // Content
  rooms       Room[]
  computers   Computer[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Room {
  id           String     @id @default(uuid())
  name         String
  description  String?
  pricePerHour Float      @default(20000)
  
  clubId       String
  club         Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  computers    Computer[]
}

model Computer {
  id           String     @id @default(uuid())
  name         String
  status       String     @default("offline") // offline, free, busy, locked, maintenance
  ipAddress    String?
  macAddress   String?
  
  clubId       String
  club         Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  roomId       String?
  room         Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  
  sessions     Session[]
}

model Session {
  id            String    @id @default(uuid())
  startTime     DateTime  @default(now())
  endTime       DateTime?
  totalCost     Float     @default(0)
  status        String    @default("active") // active, completed, cancelled
  
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  computerId    String
  computer      Computer  @relation(fields: [computerId], references: [id])
}
